# profile for non-mevis users to link to PythonQt

include ( python.prf )

INCLUDEPATH += $$PWD/../src

# check if debug or release
CONFIG(debug, debug|release) {
  DEBUG_EXT =
} else {
  DEBUG_EXT =
}

win32-g++: LIBS += $$DESTDIR/PythonQt-Qt5-Python$${PYTHON_VERSION}$${DEBUG_EXT}.dll
win32-msvc*: LIBS += $$DESTDIR/PythonQt-Qt5-Python$${PYTHON_VERSION}$${DEBUG_EXT}.lib
unix: LIBS += -L$$DESTDIR -lPythonQt-Qt5-Python$${PYTHON_VERSION}$${DEBUG_EXT}
