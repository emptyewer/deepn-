deepn++.pro:
qmake: FORCE
	@$(QMAKE) -o Makefile deepn++.pro

qmake_all: sub-deepn-qmake_all sub-gene_count-qmake_all sub-junction_make-qmake_all FORCE

make_first: sub-deepn-make_first sub-gene_count-make_first sub-junction_make-make_first  FORCE
all: sub-deepn-all sub-gene_count-all sub-junction_make-all  FORCE
clean: sub-deepn-clean sub-gene_count-clean sub-junction_make-clean  FORCE
distclean: sub-deepn-distclean sub-gene_count-distclean sub-junction_make-distclean  FORCE
	-$(DEL_FILE) Makefile
	-$(DEL_FILE) .qmake.stash
install_subtargets: sub-deepn-install_subtargets sub-gene_count-install_subtargets sub-junction_make-install_subtargets FORCE
uninstall_subtargets: sub-deepn-uninstall_subtargets sub-gene_count-uninstall_subtargets sub-junction_make-uninstall_subtargets FORCE

xcodeproj:
	@$(QMAKE) -spec macx-xcode "$(EXPORT__PRO_FILE_)"

sub-deepn-check: sub-gene_count-check sub-junction_make-check
	@test -d deepn/ || mkdir -p deepn/
	cd deepn/ && ( test -e Makefile || $(QMAKE) -o Makefile /Users/venky/Downloads/deepn-plus/deepn/deepn.pro ) && $(MAKE) -f Makefile check
sub-gene_count-check:
	@test -d gene_count/ || mkdir -p gene_count/
	cd gene_count/ && ( test -e Makefile || $(QMAKE) -o Makefile /Users/venky/Downloads/deepn-plus/gene_count/gene_count.pro ) && $(MAKE) -f Makefile check
sub-junction_make-check:
	@test -d junction_make/ || mkdir -p junction_make/
	cd junction_make/ && ( test -e Makefile || $(QMAKE) -o Makefile /Users/venky/Downloads/deepn-plus/junction_make/junction_make.pro ) && $(MAKE) -f Makefile check
check: sub-deepn-check sub-gene_count-check sub-junction_make-check

sub-deepn-benchmark: sub-gene_count-benchmark sub-junction_make-benchmark
	@test -d deepn/ || mkdir -p deepn/
	cd deepn/ && ( test -e Makefile || $(QMAKE) -o Makefile /Users/venky/Downloads/deepn-plus/deepn/deepn.pro ) && $(MAKE) -f Makefile benchmark
sub-gene_count-benchmark:
	@test -d gene_count/ || mkdir -p gene_count/
	cd gene_count/ && ( test -e Makefile || $(QMAKE) -o Makefile /Users/venky/Downloads/deepn-plus/gene_count/gene_count.pro ) && $(MAKE) -f Makefile benchmark
sub-junction_make-benchmark:
